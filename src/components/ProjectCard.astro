---
interface Props {
  project: {
    title: string;
    description: string;
    tags: string[];
    link?: string;
  };
}
const { project } = Astro.props;
const isExternal = project.link?.startsWith('http');
---

<article class="card">
  <h3>
    {project.link ? (
      <a
        href={project.link}
        target={isExternal ? '_blank' : undefined}
        rel={isExternal ? 'noopener' : undefined}
      >
        {project.title}
        {isExternal && <span class="ext">↗</span>}
      </a>
    ) : (
      project.title
    )}
  </h3>
  <p>{project.description}</p>
  <div class="tags">
    {project.tags.map((t) => <span class="tag">{t}</span>)}
  </div>
</article>

<style>
  h3 a { color: inherit; }
  h3 a:hover { color: var(--accent); text-decoration: none; }
  .ext {
    font-size: 0.8em;
    color: var(--text-faint);
    margin-left: 4px;
  }
</style>
