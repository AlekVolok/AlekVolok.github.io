---
import Base from '../layouts/Base.astro';
import { site } from '../data/site.js';
---

<Base title="About" description="About Aleksandr Kozlov — technical artist working with Houdini, Python and real-time graphics.">
  <section class="section">
    <div class="container about">
      <h1 class="page-title">About</h1>
      <div class="prose">
        <p>
          I'm <strong>{site.name}</strong>, a technical artist focused on the
          space between art and engineering: procedural content, DCC tooling,
          and the pipelines that hold production together.
        </p>
        <p>
          My day-to-day toolkit is Houdini and Python, with frequent detours
          into NumPy for heavy geometry and volume processing, and GLSL when
          things need to run in real time. I like problems where the answer is
          a system, not a one-off asset.
        </p>
        <p>
          This site is a static build (Astro) with hand-written WebGL2 shader
          demos — you can find the source on GitHub.
        </p>
      </div>

      <h2 class="section-title" style="margin-top: 48px;">Contact</h2>
      <ul class="contact">
        <li><span class="label">Email</span><a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li><span class="label">GitHub</span><a href={site.github} target="_blank" rel="noopener">AlekVolok</a></li>
        <li><span class="label">LinkedIn</span><a href={site.linkedin} target="_blank" rel="noopener">aleksandr-kozlov</a></li>
      </ul>
    </div>
  </section>
</Base>

<style>
  .page-title { font-size: 2.4rem; margin-bottom: 24px; }
  .contact {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .contact li {
    display: flex;
    gap: 20px;
    align-items: baseline;
  }
  .contact .label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-faint);
    width: 80px;
  }
</style>
