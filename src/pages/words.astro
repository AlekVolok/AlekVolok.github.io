---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Word Pairs</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <main class="game-page">
      <div class="game" id="game">
        <div class="controls">
          <select id="topicSelect"></select>
          <button id="reloadBtn" class="btn">Reload</button>
        </div>
        <div class="stats">
          <span id="score">Score: 0</span>
          <span id="mistakes">Mistakes: 0</span>
          <span id="multiplier">Multiplier: x1</span>
          <span id="timer">Time: 00:00</span>
          <span id="page" aria-live="polite">Page: 0/0</span>
        </div>
        <div class="words-container">
          <div id="leftWords" class="word-col"></div>
          <div id="rightWords" class="word-col"></div>
        </div>
      </div>
    </main>
  </body>
</html>

<script>
  type Pairs = Record<string, string>;
  type Pair = [string, string];
  type PageType = 'regular' | 'penalty';

  let selectedLeft: string | null = null;
  let selectedRight: string | null = null;
  let pairs: Pairs = {};
  let regularPages: Pair[][] = [];
  let currentPagePairs: Pair[] = [];
  let currentRegularPageIndex = 0;
  let currentPenaltyPage = 0;
  let pageType: PageType = 'regular';
  let pendingPenaltyPairs: Pair[] = [];
  let queuedPenaltyKeys = new Set<string>();
  let missedPairsOnCurrentPage = new Set<string>();
  let correctlyGuessedPairs = 0;
  let score = 0;
  let mistakes = 0;
  let comboMultiplier = 1;
  let comboCount = 0;
  const numberRows = 8;
  const maxRegularPages = 5;
  const pointsPerCorrectAnswer = 10;
  const pointsDecayIntervalMs = 5_000;
  let gameStartedAt = 0;
  let pageStartedAt = 0;
  let lastActionAt = 0;
  let inactivitySteps = 0;
  let gameActive = false;

  const $ = <T extends Element>(sel: string) =>
    document.querySelector<T>(sel)!;

  const leftWordsEl = $<HTMLDivElement>('#leftWords');
  const rightWordsEl = $<HTMLDivElement>('#rightWords');
  const topicSelect = $<HTMLSelectElement>('#topicSelect');
  const scoreEl = $<HTMLSpanElement>('#score');
  const mistakesEl = $<HTMLSpanElement>('#mistakes');
  const multiplierEl = $<HTMLSpanElement>('#multiplier');
  const timerEl = $<HTMLSpanElement>('#timer');
  const pageEl = $<HTMLSpanElement>('#page');

  function shuffle<T>(items: T[]): T[] {
    return [...items].sort(() => Math.random() - 0.5);
  }

  function formatTime(milliseconds: number): string {
    const totalSeconds = Math.floor(milliseconds / 1_000);
    const minutes = Math.floor(totalSeconds / 60).toString().padStart(2, '0');
    const seconds = (totalSeconds % 60).toString().padStart(2, '0');
    return `${minutes}:${seconds}`;
  }

  function makeButton(word: string, onClick: () => void): HTMLButtonElement {
    const btn = document.createElement('button');
    btn.textContent = word;
    btn.dataset.word = word;
    btn.addEventListener('click', onClick);
    return btn;
  }

  function loadPage(page: Pair[], nextPageType: PageType) {
    correctlyGuessedPairs = 0;
    leftWordsEl.innerHTML = '';
    rightWordsEl.innerHTML = '';
    selectedLeft = null;
    selectedRight = null;
    missedPairsOnCurrentPage = new Set<string>();
    currentPagePairs = page;
    pageType = nextPageType;
    pageStartedAt = Date.now();

    const leftWords = currentPagePairs.map(([left]) => left);
    const rightWords = shuffle(currentPagePairs.map(([, right]) => right));

    leftWords.forEach((word) => {
      leftWordsEl.appendChild(makeButton(word, () => onLeftClick(word)));
    });

    rightWords.forEach((word) => {
      rightWordsEl.appendChild(makeButton(word, () => onRightClick(word)));
    });

    updateUI();
  }

  function queuePenaltyPair(leftWord: string) {
    if (queuedPenaltyKeys.has(leftWord)) return;

    const pair = currentPagePairs.find(([left]) => left === leftWord);
    if (!pair) return;

    pendingPenaltyPairs.push(pair);
    queuedPenaltyKeys.add(leftWord);
  }

  function markPairForPenalty(leftWord: string) {
    missedPairsOnCurrentPage.add(leftWord);
  }

  function loadNextPage() {
    missedPairsOnCurrentPage.forEach(queuePenaltyPair);

    if (pageType === 'regular' && currentRegularPageIndex < regularPages.length - 1) {
      currentRegularPageIndex += 1;
      loadPage(regularPages[currentRegularPageIndex], 'regular');
      return;
    }

    if (pendingPenaltyPairs.length > 0) {
      const nextPenaltyPage = pendingPenaltyPairs.splice(0, numberRows);
      nextPenaltyPage.forEach(([left]) => queuedPenaltyKeys.delete(left));
      currentPenaltyPage += 1;
      loadPage(nextPenaltyPage, 'penalty');
      return;
    }

    gameActive = false;
    pageEl.textContent = `Complete in ${formatTime(Date.now() - gameStartedAt)}`;
    updateUI();
  }

  function getPointsForCorrectAnswer(): number {
    const elapsedSteps = Math.floor((Date.now() - pageStartedAt) / pointsDecayIntervalMs);
    const timeAdjustedPoints = Math.max(1, pointsPerCorrectAnswer - elapsedSteps);
    return timeAdjustedPoints * comboMultiplier;
  }

  function checkPair(leftWord: string, rightWord: string) {
    document.querySelectorAll('.selected').forEach((el) => el.classList.remove('selected'));
    if (pairs[leftWord] === rightWord) {
      correctlyGuessedPairs += 1;
      score += getPointsForCorrectAnswer();
      markCorrect(leftWord, rightWord);
      if (correctlyGuessedPairs === currentPagePairs.length) {
        loadNextPage();
      }
    } else {
      mistakes += 1;
      score -= 5;
      comboCount = 0;
      comboMultiplier = 1;
      markPairForPenalty(leftWord);
      const pairWithSelectedTranslation = currentPagePairs.find(([, right]) => right === rightWord);
      if (pairWithSelectedTranslation) {
        markPairForPenalty(pairWithSelectedTranslation[0]);
      }
      markIncorrect(leftWord, rightWord);
    }
    selectedLeft = null;
    selectedRight = null;
    updateUI();
  }

  function markCorrect(leftWord: string, rightWord: string) {
    leftWordsEl.querySelector(`[data-word="${CSS.escape(leftWord)}"]`)?.classList.add('correct');
    rightWordsEl.querySelector(`[data-word="${CSS.escape(rightWord)}"]`)?.classList.add('correct');
    comboCount += 1;
    if (comboCount % 3 === 0) comboMultiplier += 1;
  }

  function markIncorrect(leftWord: string, rightWord: string) {
    const l = leftWordsEl.querySelector(`[data-word="${CSS.escape(leftWord)}"]`);
    const r = rightWordsEl.querySelector(`[data-word="${CSS.escape(rightWord)}"]`);
    l?.classList.add('incorrect');
    r?.classList.add('incorrect');
    setTimeout(() => {
      l?.classList.remove('incorrect');
      r?.classList.remove('incorrect');
    }, 700);
  }

  function onLeftClick(word: string) {
    if (leftWordsEl.querySelector(`[data-word="${CSS.escape(word)}"]`)?.classList.contains('correct')) return;
    recordAction();
    document.querySelectorAll('.selected').forEach((el) => el.classList.remove('selected'));
    if (selectedRight) {
      checkPair(word, selectedRight);
    } else {
      selectedLeft = word;
      leftWordsEl.querySelector(`[data-word="${CSS.escape(word)}"]`)?.classList.add('selected');
    }
  }

  function onRightClick(word: string) {
    if (rightWordsEl.querySelector(`[data-word="${CSS.escape(word)}"]`)?.classList.contains('correct')) return;
    recordAction();
    document.querySelectorAll('.selected').forEach((el) => el.classList.remove('selected'));
    if (selectedLeft) {
      checkPair(selectedLeft, word);
    } else {
      selectedRight = word;
      rightWordsEl.querySelector(`[data-word="${CSS.escape(word)}"]`)?.classList.add('selected');
    }
  }

  let allTopicSlugs: string[] = [];

  function recordAction() {
    lastActionAt = Date.now();
    inactivitySteps = 0;
    updateUI();
  }

  function tickTimer() {
    if (!gameActive) return;

    const idleSteps = Math.floor((Date.now() - lastActionAt) / pointsDecayIntervalMs);
    if (idleSteps > inactivitySteps) {
      comboMultiplier = Math.max(1, comboMultiplier - (idleSteps - inactivitySteps));
      inactivitySteps = idleSteps;
    }
    updateUI();
  }

  async function loadWords() {
    score = 0;
    mistakes = 0;
    comboMultiplier = 1;
    comboCount = 0;
    const topic = topicSelect.value;

    if (topic === '__random__') {
      const results = await Promise.all(
        allTopicSlugs.map((slug) =>
          fetch(`/words/topics/${encodeURIComponent(slug)}.json`).then((res) => res.json())
        )
      );
      pairs = Object.assign({}, ...(results as Pairs[]));
    } else {
      const res = await fetch(`/words/topics/${encodeURIComponent(topic)}.json`);
      pairs = await res.json();
    }

    const selectedPairs = shuffle(Object.entries(pairs)).slice(0, numberRows * maxRegularPages);
    regularPages = Array.from(
      { length: Math.ceil(selectedPairs.length / numberRows) },
      (_, index) => selectedPairs.slice(index * numberRows, (index + 1) * numberRows)
    );
    currentRegularPageIndex = 0;
    currentPenaltyPage = 0;
    pendingPenaltyPairs = [];
    queuedPenaltyKeys = new Set<string>();
    gameStartedAt = Date.now();
    lastActionAt = gameStartedAt;
    inactivitySteps = 0;
    gameActive = regularPages.length > 0;

    if (gameActive) {
      loadPage(regularPages[0], 'regular');
    } else {
      leftWordsEl.innerHTML = '';
      rightWordsEl.innerHTML = '';
      pageEl.textContent = 'No words available';
      updateUI();
    }
  }

  function updateUI() {
    scoreEl.textContent = `Score: ${score}`;
    mistakesEl.textContent = `Mistakes: ${mistakes}`;
    multiplierEl.textContent = `Multiplier: x${comboMultiplier}`;
    timerEl.textContent = `Time: ${formatTime(Date.now() - gameStartedAt)}`;
    if (gameActive) {
      pageEl.textContent = pageType === 'regular'
        ? `Page: ${currentRegularPageIndex + 1}/${regularPages.length}`
        : `Penalty page: ${currentPenaltyPage}`;
    }
    scoreEl.classList.toggle('negative', score < 0);
    scoreEl.classList.toggle('high', score >= 1000);
  }

  async function init() {
    const res = await fetch('/words/topics.json');
    const topics: { slug: string; label: string }[] = await res.json();
    allTopicSlugs = topics.map((t) => t.slug);

    const randomOpt = document.createElement('option');
    randomOpt.value = '__random__';
    randomOpt.textContent = 'Random (all topics)';
    topicSelect.appendChild(randomOpt);

    topics.forEach(({ slug, label }) => {
      const opt = document.createElement('option');
      opt.value = slug;
      opt.textContent = label;
      topicSelect.appendChild(opt);
    });
    await loadWords();
  }

  topicSelect.addEventListener('change', loadWords);
  $('#reloadBtn').addEventListener('click', loadWords);

  window.setInterval(tickTimer, 1_000);
  init();
</script>

<style>
  .game-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 24px;
  }

  .game {
    width: 100%;
    max-width: 640px;
  }

  .controls {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
  }
  .controls select {
    background: var(--bg-raised);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.92rem;
    font-family: var(--font-sans);
    flex: 1;
  }
  .controls select:focus {
    outline: none;
    border-color: var(--accent);
  }

  .stats {
    display: flex;
    gap: 20px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 24px;
  }
  #score.negative { color: #f08080; }
  #score.high { color: var(--accent); }

  .words-container {
    display: flex;
    gap: 24px;
  }
  .word-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  @media (max-width: 520px) {
    .controls { flex-direction: column; }
    .stats { flex-wrap: wrap; gap: 12px; }
  }
</style>

<style is:global>
  .word-col button {
    appearance: none;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    padding: 18px 16px;
    font-size: 0.95rem;
    font-family: var(--font-sans);
    text-align: left;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, transform 0.1s;
  }
  .word-col button:hover:not(:disabled) {
    border-color: var(--border-hover);
  }
  .word-col button.selected {
    border-color: var(--accent);
    background: var(--accent-dim);
    color: var(--accent);
  }
  .word-col button.correct {
    border-color: var(--accent);
    background: var(--accent-dim);
    color: var(--accent);
    opacity: 0.55;
    cursor: default;
  }
  .word-col button.incorrect {
    border-color: #f08080;
    background: rgba(240, 128, 128, 0.12);
    color: #f08080;
  }
</style>
